<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Raiden vs Yixuan Tic Tac Toe</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI,sans-serif;
}

body{
background:linear-gradient(135deg,#1a1038,#2d1b69,#4c2d91);
height:100vh;
display:flex;
justify-content:center;
align-items:center;
}

.game{
display:flex;
align-items:center;
gap:35px;
}

.side img{
width:220px;
height:330px;
object-fit:cover;
border-radius:18px;
box-shadow:0 15px 30px rgba(0,0,0,.35);
}

.container{
width:420px;
padding:25px;
background:rgba(255,255,255,.08);
backdrop-filter:blur(12px);
border-radius:20px;
box-shadow:0 15px 30px rgba(0,0,0,.3);
}

h1{
text-align:center;
color:white;
margin-bottom:20px;
}

.status{
text-align:center;
color:#e9d5ff;
font-size:20px;
margin-bottom:20px;
font-weight:bold;
}

.board{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:12px;
}

.cell{
aspect-ratio:1;
border:none;
border-radius:14px;
font-size:55px;
background:rgba(255,255,255,.08);
color:white;
cursor:pointer;
transition:.2s;
}

.cell:hover{
background:rgba(255,255,255,.15);
transform:scale(1.03);
}

.win{
background:#8b5cf6!important;
}

#restart{
margin-top:20px;
width:100%;
padding:14px;
border:none;
border-radius:12px;
background:#7c3aed;
color:white;
font-size:17px;
cursor:pointer;
}

#restart:hover{
background:#6d28d9;
}

@media(max-width:900px){

.game{
flex-direction:column;
}

.side img{
width:180px;
height:250px;
}

}

</style>

</head>

